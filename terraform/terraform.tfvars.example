# terraform.tfvars.example
# Copy to terraform.tfvars (git-ignored) and fill in real values.
# Alternatively, pass via: terraform plan -var="student_id=abc123"
# Or set env var: export TF_VAR_student_id=abc123

region          = "us-east-1"
student_id      = "YOUR-STUDENT-ID-HERE"   # <-- required, must be unique

cluster_name    = "project-bedrock-cluster"
cluster_version = "1.34"
vpc_name        = "project-bedrock-vpc"

node_instance_type = "t3.medium"
node_desired_size  = 2
node_min_size      = 1
node_max_size      = 4

mysql_db_name    = "retailcatalog"
mysql_username   = "catalogadmin"
postgres_db_name = "retailorders"
postgres_username = "ordersadmin"
rds_instance_class = "db.t3.micro"

dynamodb_cart_table = "retail-store-cart"

# CI/CD pipeline test
